# Concierge Cloud Run API base URL
VITE_CONCIERGE_API_URL=https://career-concierge-api-XXXXX-ew.a.run.app

# Firebase web app config for the active project
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore database id for this variant
VITE_FIREBASE_DATABASE_ID=career-concierge

# Optional Gemini model overrides for API service
GEMINI_MODEL_FAST=gemini-3-flash-preview
GEMINI_MODEL_IMAGE=gemini-2.5-flash-image-preview
GEMINI_MODEL_VIDEO=veo-3.1-generate-preview
GEMINI_MODEL_LIVE_VOICE=gemini-2.5-flash-native-audio-preview-12-2025
