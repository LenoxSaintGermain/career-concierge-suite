rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Staff access is managed via custom claims (set with Admin SDK).
    function isStaff() {
      return isSignedIn() && request.auth.token.staff == true;
    }

    function isClient(clientId) {
      return isSignedIn() && request.auth.uid == clientId;
    }

    // ---------------------------------------------------------
    // CAREER CONCIERGE RULES (AUTH REQUIRED)
    // ---------------------------------------------------------
    // Data model (MVP):
    // - clients/{clientId}
    // - clients/{clientId}/artifacts/{artifactType}
    //
    // Principle:
    // - Clients can only read/write their own documents.
    // - Staff (claim: staff=true) can read client docs (write can be tightened later).
    // ---------------------------------------------------------
    match /clients/{clientId} {
      allow read: if isClient(clientId) || isStaff();
      allow create, update: if isClient(clientId);
      allow delete: if false;

      match /artifacts/{artifactId} {
        allow read: if isClient(clientId) || isStaff();
        allow create, update: if isClient(clientId);
        allow delete: if false;
      }

      // Future subcollections (placeholders)
      match /{subCollection}/{docId} {
        allow read, write: if false;
      }
    }
  }
}
